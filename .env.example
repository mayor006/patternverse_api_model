# ─── Environment toggle ───────────────────────────────────────────────
# "development" → uses Ollama (local). "production" → uses Hugging Face.
# This is the ONLY thing you change to switch model backends.
APP_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────
# Leave blank to run with the built-in in-memory store (dev/testing only).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: a server-side service-role key. If set, the backend uses it
# (RLS is bypassed for trusted server operations). Falls back to the anon
# key when unset. Never expose the service-role key to a browser client.
SUPABASE_SERVICE_KEY=

# ─── Hugging Face (production) ────────────────────────────────────────
HF_API_TOKEN=
HF_MODEL_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.3

# ─── Ollama (local dev) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
